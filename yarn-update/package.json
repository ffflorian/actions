{
  "name": "yarn-update",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action: check for yarn updates and create a pull request",
  "main": "dist/index.js",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js --minify",
    "format:check": "prettier --list-different \"src/**/*.ts\"",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@ffflorian/prettier-config": "0.8.2",
    "@types/node": "24.12.2",
    "@types/semver": "7.7.1",
    "esbuild": "0.28.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
