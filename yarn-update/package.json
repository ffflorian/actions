{
  "name": "yarn-update",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action: check for yarn updates and create a pull request",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --minify",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
