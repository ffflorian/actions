{
  "name": "yarn-update",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action: check for yarn updates and create a pull request",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --minify",
    "format:check": "prettier --list-different \"src/**/*.ts\"",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@ffflorian/prettier-config": "0.7.0",
    "@types/node": "22.x",
    "@types/semver": "^7.7.1",
    "esbuild": "0.28.0",
    "prettier": "3.8.1",
    "typescript": "6.0.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
