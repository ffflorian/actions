{
  "name": "coolify-deploy-action",
  "description": "GitHub Action which triggers Coolify deployments",
  "private": true,
  "version": "1.0.0",
  "packageManager": "yarn@4.14.1",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "3.0.1"
  },
  "devDependencies": {
    "@ffflorian/prettier-config": "0.8.2",
    "@types/node": "25.9.1",
    "esbuild": "0.28.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "prettier": "@ffflorian/prettier-config",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node26 --outfile=dist/index.js",
    "format:check": "prettier --list-different \"src/**/*.ts\"",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  }
}
