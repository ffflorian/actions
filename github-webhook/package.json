{
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1"
  },
  "description": "Send GitHub-style webhook requests from workflows",
  "devDependencies": {
    "@ffflorian/prettier-config": "0.8.2",
    "@types/node": "25.0.0",
    "esbuild": "0.28.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "name": "github-webhook-action",
  "packageManager": "yarn@4.14.1",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node26 --outfile=dist/index.js",
    "format:check": "prettier --list-different \"src/**/*.ts\"",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0"
}
