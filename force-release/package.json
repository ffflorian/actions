{
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0"
  },
  "description": "GitHub Action which updates semantic-release rules and runs semantic-release",
  "devDependencies": {
    "@ffflorian/prettier-config": "0.8.2",
    "@types/node": "25.9.3",
    "esbuild": "0.28.1",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "name": "force-release-action",
  "packageManager": "yarn@4.16.0",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node26 --format=cjs --outfile=dist/index.js --minify",
    "fix": "prettier --write src/",
    "lint": "prettier --check src/",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0"
}
