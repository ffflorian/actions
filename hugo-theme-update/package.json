{
  "name": "hugo-theme-update",
  "version": "1.0.0",
  "description": "GitHub Action to update Hugo modules and create a pull request",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "format": "prettier --write src/",
    "lint": "prettier --check src/"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
