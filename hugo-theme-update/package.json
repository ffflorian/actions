{
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "description": "GitHub Action which updates Hugo modules and creates a pull request",
  "devDependencies": {
    "@ffflorian/prettier-config": "1.0.0",
    "@types/node": "~26",
    "esbuild": "0.28.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "name": "hugo-theme-update-action",
  "prettier": "@ffflorian/prettier-config",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node26 --outfile=dist/index.js",
    "fix": "prettier --write src/",
    "lint": "prettier --check src/",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0",
  "packageManager": "yarn@4.17.0"
}
