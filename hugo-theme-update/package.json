{
  "name": "hugo-theme-update",
  "version": "1.0.0",
  "description": "GitHub Action to update Hugo modules and create a pull request",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "format": "prettier --write src/",
    "lint": "prettier --check src/",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3"
  }
}
